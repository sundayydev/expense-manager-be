# ============================================================
# EXPENSE MANAGER - Environment Variables
# ============================================================
# Sao chép file này thành .env và điền giá trị thực

# ------------------------------------------------------------
# DATABASE
# Dùng Neon PostgreSQL: https://neon.tech
# Format: postgresql://user:password@host/dbname?sslmode=require
# ------------------------------------------------------------
DATABASE_URL="postgresql://user:password@ep-xxxxx.us-east-1.aws.neon.tech/expense_db?sslmode=require"

# ------------------------------------------------------------
# APP CONFIG
# ------------------------------------------------------------
NODE_ENV="development"
PORT=3000

# ------------------------------------------------------------
# JWT AUTH (sẽ cần khi implement authentication)
# ------------------------------------------------------------
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-this-in-production"
JWT_REFRESH_EXPIRES_IN="7d"

# ------------------------------------------------------------
# NEON ADAPTER
# Đặt thành "true" khi deploy lên Koyeb/Cloudflare để dùng Neon HTTP adapter
# Đặt thành "false" khi chạy local với PostgreSQL thông thường
# ------------------------------------------------------------
USE_NEON_ADAPTER="false"

# ------------------------------------------------------------
# FILE UPLOAD (Cloudflare R2 hoặc AWS S3)
# ------------------------------------------------------------
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key"
R2_SECRET_ACCESS_KEY="your-r2-secret-key"
R2_BUCKET_NAME="expense-manager-attachments"
R2_PUBLIC_URL="https://pub-xxx.r2.dev"
